class Solution {
public:
    vector<int> intersect(vector<int>& nums1, vector<int>& nums2) {
        map<int, int> mp;
        vector<int> res;

        for (int i = 0; i < nums1.size(); i++) {
            mp[nums1[i]]++;
        }

        for (auto it : nums2) {
            if (mp[it] > 0) {
                res.push_back(it);
                mp[it]--;
            }
        }

        return res;
    }
};
