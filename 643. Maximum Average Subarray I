class Solution {
public:
    double findMaxAverage(vector<int>& nums, int k) {
        double windowSum = 0, maxi = INT_MIN;

        for (int i = 0; i < k; i++) {
            windowSum += nums[i];
        }

        maxi = max(maxi, windowSum / k);

        for (int i = k; i < nums.size(); i++) {
            windowSum -= nums[i - k];
            windowSum += nums[i];
            maxi = max(maxi, windowSum / k);
        }

        return maxi;
    }
};
