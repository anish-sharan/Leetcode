class Solution {
public:
    vector<string> findRepeatedDnaSequences(string s) {
        map<string, int> mp;
        vector<string> res;
        if(s.size()<10)
        {
            return res;
        }
        for (int i = 0; i <= s.size() - 10; i++) {
            cout << s.substr(i, 10) << endl;
            mp[s.substr(i, 10)]++;
        }
        for (auto it : mp) {
            if (it.second > 1) {
                res.push_back(it.first);
            }
        }

        return res;
    }
};
