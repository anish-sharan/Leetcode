class Solution {
public:
    int lengthOfLongestSubstring(string s) {
        int l = 0, maxLength = 0;
        set<char> seen;

        for (int r = 0; r < s.length(); r++) {
            while (seen.find(s[r]) != seen.end()) {
                seen.erase(s[l]);
                l++;
            }

            seen.insert(s[r]);

            maxLength = max(maxLength, r - l + 1);
        }

        return maxLength;
    }
};
