class Solution {
public:
    int reverse(int n) {
        long long rev = 0;
        while (n > 0) {
            rev += n % 10;
            rev *= 10;
            n /= 10;
        }

        return rev / 10;
    }
    int mirrorDistance(int n) {
        int rev = reverse(n);
        return abs(n - rev);
    }
};
