class Solution {
public:
    int findContentChildren(vector<int>& g, vector<int>& s) {
        sort(s.begin(), s.end());
        sort(g.begin(), g.end());

        int count = 0, n = s.size(), pointer = 0;

        for (int i = 0; i < g.size() && pointer < n; i++) {
            while (pointer < n && s[pointer] < g[i]) {
                pointer++;
            }

            if (pointer < n) {
                count++;
                cout << "-> " << g[i] << " " << s[pointer] << endl;
                pointer++; 
            }
        }

        return count;
    }
};
