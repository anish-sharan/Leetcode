class Solution {
public:
    bool lemonadeChange(vector<int>& bills) {
        int f = 0, t = 0, tw = 0;

        for (auto it : bills) {
            if (it == 5) {
                f++;
            }

            else if (it == 10) {
                t++;
                if (f > 0) {
                    f--;
                } else {
                    return false;
                }
            }

            if (it == 20) {
                tw++;

                if (t > 0 && f > 0) {
                    t--;
                    f--;
                } else if (f > 2) {
                    f--;
                    f--;
                    f--;
                } else {
                    return false;
                }
            }
        }

        return true;
    }
};
