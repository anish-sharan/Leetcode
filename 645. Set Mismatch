class Solution {
public:
    vector<int> findErrorNums(vector<int>& nums) {
        vector<int> v(nums.size(), 0), res(2,-1);

        for (auto it : nums) {
            v[it - 1]++;
        }

        for (int i = 0; i < nums.size(); i++) {
            if (v[i] > 1) {
                res[0] = i + 1;
            }

            else if (v[i] == 0) {
                res[1] = i + 1;
            }
        }

        return res;
    }
};
